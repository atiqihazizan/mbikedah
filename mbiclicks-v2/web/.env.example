# Database
DATABASE_URL="mysql://DB_USER:DB_PASS@127.0.0.1:3306/DB_NAME"

# JWT
JWT_ACCESS_SECRET=ganti_dengan_secret_sebenar
JWT_REFRESH_SECRET=ganti_dengan_secret_sebenar
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Server
PORT=4000
NODE_ENV=production

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# AutoCount API
AUTOCOUNT_API_URL=http://IP_AUTOCOUNT:3000
AUTOCOUNT_API_KEY=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="MBI Portal <noreply@mbi.gov.my>"

# URL aplikasi (guna domain sebenar dalam production)
APP_URL=https://mbiclick2.mahsites.net
