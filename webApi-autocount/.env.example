# Server
PORT=3000
NODE_ENV=development

# ─── Database — Windows Authentication ───────────────────────────────────────
# Server name  : SERVERK\A2006  →  DB_SERVER=SERVERK  DB_INSTANCE=A2006
# Database     : AED_MBI
DB_SERVER=SERVERK
DB_INSTANCE=A2006
DB_DATABASE=AED_MBI
DB_CONNECTION_TIMEOUT=30000
DB_REQUEST_TIMEOUT=30000
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_IDLE_TIMEOUT=30000

# ─── Security ─────────────────────────────────────────────────────────────────
# Kosongkan untuk disable auth semasa development
API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
