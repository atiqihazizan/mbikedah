<!DOCTYPE html>
<html lang="ms">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Laporan Penyelenggaraan Server</title>
  <style>
    @media print {
      body {
        margin: 0;
        font-size: 10px;
        line-height: 1.1;
        padding: 5px;
      }

      .no-print {
        display: none;
      }

      /* Optimize spacing for print */
      .header {
        padding-bottom: 0px;
        margin-bottom: 1px;
      }

      .header h1 {
        font-size: 16px;
        margin: 0;
      }

      .section {
        margin-bottom: 0px;
      }

      .section h2 {
        font-size: 12px;
        margin-bottom: 0px;
        padding-bottom: 1px;
      }

      .info-table {
        margin-bottom: 0px;
        font-size: 8px;
      }

      .info-table th,
      .info-table td {
        padding: 2px 3px;
        border: 1px solid #ddd;
      }

      .info-table th {
        font-size: 7px;
        font-weight: bold;
      }

      .label {
        width: 100px;
        font-size: 7px;
      }

      .measurement {
        font-size: 7px;
        padding: 1px 2px;
      }

      .signature-section {
        margin-top: 1px;
        gap: 2px;
      }

      .signature-box {
        padding: 0px;
        font-size: 7px;
      }

      .signature-line {
        height: 10px;
        margin: 1px 0;
      }

      .footer {
        margin-top: 0px;
        padding-top: 0px;
        font-size: 6px;
      }

      /* Force single page */
      html,
      body {
        height: auto;
      }

      .section {
        page-break-inside: avoid;
      }

      /* Compact tables */
      .info-table tbody tr {
        page-break-inside: avoid;
      }

      /* Ensure everything fits on one page */
      @page {
        size: A4;
      }

      body {
        -webkit-print-color-adjust: exact;
        color-adjust: exact;
        max-height: 100vh;
        overflow: hidden;
      }

      /* Compress content vertically */
      * {
        line-height: 1.0 !important;
      }
    }

    @font-face {
      font-family: 'Audiowide';
      src: url('Audiowide-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    body {
      font-family: Arial, sans-serif;
      line-height: 1.3;
      color: #333;
      max-width: 800px;
      margin: 0 auto;
      padding: 15px;
      background: white;
      font-size: 12px;
    }

    .print-controls {
      position: fixed;
      top: 20px;
      right: 20px;
      background: #333;
      padding: 10px;
      border-radius: 5px;
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    }

    .print-controls button {
      background: #007bff;
      color: white;
      border: none;
      padding: 10px 20px;
      margin: 5px;
      border-radius: 3px;
      cursor: pointer;
      font-size: 14px;
    }

    .print-controls button:hover {
      background: #0056b3;
    }

    .file-input {
      margin: 5px;
      padding: 5px;
      background: white;
      border: 1px solid #ddd;
      border-radius: 3px;
      font-size: 12px;
    }

    /* Logo Section */
    .logo-section {
      text-align: center;
      margin-bottom: 15px;
      padding: 15px 0;
      border-bottom: 1px solid #eee;
    }

    .company-logo {
      margin-bottom: 10px;
    }

    .company-logo svg {
      width: 160px;
      height: 60px;
      margin-bottom: 8px;
    }

    .company-info {
      font-size: 11px;
      color: #666;
      margin-top: 8px;
      line-height: 1.3;
    }

    .company-name {
      font-size: 14px;
      font-weight: bold;
      color: #2d8c8c;
      margin-bottom: 4px;
    }

    /* Customer Section */
    .customer-section {
      background: #f8f9fa;
      border: 1px solid #ddd;
      border-radius: 5px;
      padding: 15px;
      margin-bottom: 15px;
    }

    .customer-section h2 {
      color: #2d8c8c;
      font-size: 14px;
      margin: 0 0 10px 0;
      border-bottom: 1px solid #ddd;
      padding-bottom: 4px;
    }

    .customer-info {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
      font-size: 12px;
      line-height: 1.3;
    }

    .customer-info .customer-name {
      font-weight: bold;
      color: #333;
      margin-bottom: 4px;
    }

    .customer-info .customer-details {
      color: #666;
    }

    .customer-info .attention {
      color: #2d8c8c;
      font-weight: bold;
    }

    .header {
      text-align: center;
      border-bottom: 2px solid #333;
      padding-bottom: 15px;
      margin-bottom: 20px;
    }

    .header h1 {
      color: #2d8c8c;
      margin: 0;
      font-size: 20px;
    }

    .header .subtitle {
      color: #666;
      font-size: 12px;
      margin-top: 4px;
    }

    .section {
      margin-bottom: 18px;
    }

    .section h2 {
      color: #2d8c8c;
      border-bottom: 1px solid #ddd;
      padding-bottom: 4px;
      margin-bottom: 10px;
      font-size: 16px;
    }

    .info-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 15px;
      font-size: 11px;
    }

    .info-table th,
    .info-table td {
      border: 1px solid #ddd;
      padding: 6px 8px;
      text-align: left;
    }

    .info-table th {
      background-color: #f5f5f5;
      font-weight: bold;
      font-size: 10px;
    }

    .info-table tr:nth-child(even) {
      background-color: #f9f9f9;
    }

    .label {
      font-weight: bold;
      background-color: #f0f0f0;
      width: 160px;
      font-size: 10px;
    }

    .status-ok {
      color: #28a745;
      font-weight: bold;
    }

    .status-warning {
      color: #ffc107;
      font-weight: bold;
    }

    .status-error {
      color: #dc3545;
      font-weight: bold;
    }

    .measurement {
      font-family: monospace;
      background: #f8f9fa;
      padding: 1px 4px;
      border-radius: 3px;
      font-size: 10px;
    }

    .loading {
      text-align: center;
      padding: 30px;
      font-size: 14px;
      color: #666;
    }

    .error {
      text-align: center;
      padding: 30px;
      font-size: 14px;
      color: #dc3545;
      background: #f8d7da;
      border: 1px solid #f5c6cb;
      border-radius: 5px;
      margin: 15px;
    }

    .notes {
      background: #f8f9fa;
      border: 1px solid #ddd;
      padding: 10px;
      border-radius: 5px;
      margin-top: 8px;
      font-size: 11px;
    }

    .signature-section {
      margin-top: 25px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
    }

    .signature-box {
      border: 1px solid #ddd;
      padding: 15px;
      text-align: center;
      font-size: 11px;
    }

    .signature-line {
      border-bottom: 1px solid #333;
      height: 40px;
      margin: 15px 0;
      display: flex;
      align-items: flex-end;
      padding-bottom: 4px;
    }

    .footer {
      margin-top: 20px;
      text-align: center;
      font-size: 10px;
      color: #666;
      border-top: 1px solid #ddd;
      padding-top: 10px;
    }

    .section table tr th:first-child,
    .section table tr td:first-child {
      white-space: nowrap;
      width: 150px;
    }

    .remark {
      width: 230px;
    }

    .status {
      width: 30px;
    }

    .cond {
      width: 40px;
    }

    .company-logo,
    .signature-section {
      display: none;
    }

    .font-audiowide {
      font-family: audiowide;
    }

    code {
      background: #f4f4f4;
      padding: 2px 6px;
      border-radius: 3px;
      font-family: 'Courier New', monospace;
      font-size: 10px;
      color: #d63384;
    }

    h3 {
      font-weight: bold;
    }
  </style>
</head>

<body>
  <div class="print-controls no-print">
    <input type="file" id="jsonFileInput" class="file-input" accept=".json" onchange="loadFromFile()"
      title="Muat fail JSON (Default: folder preventive_maintenance)">
    <button onclick="printReport()">🖨️ Cetak Laporan</button>
  </div>

  <div id="loading" class="loading">
    ⚠️ Sila muat fail data JSON atau gunakan data contoh untuk memaparkan laporan
  </div>

  <div id="error" class="error" style="display: none;">
    <h3>❌ Ralat Memuat Data</h3>
    <p id="error-message">-</p>
    <button
      onclick="document.getElementById('error').style.display='none'; document.getElementById('loading').style.display='block';">Tutup</button>
  </div>

  <div id="report-content" style="display: none;">
    <!-- Logo Section -->
    <div class="logo-section">
      <div class="company-logo">
        <svg viewBox="0 0 200 80" xmlns="http://www.w3.org/2000/svg">
          <!-- Background circle -->
          <circle cx="40" cy="40" r="35" fill="#2d8c8c" stroke="#1a5f5f" stroke-width="2" />

          <!-- Engineering/Tech icon elements -->
          <g fill="white">
            <!-- Gear/Settings icon -->
            <circle cx="30" cy="30" r="8" fill="none" stroke="white" stroke-width="2" />
            <circle cx="30" cy="30" r="3" fill="white" />
            <rect x="28" y="22" width="4" height="6" fill="white" />
            <rect x="28" y="42" width="4" height="6" fill="white" />
            <rect x="22" y="28" width="6" height="4" fill="white" />
            <rect x="42" y="28" width="6" height="4" fill="white" />

            <!-- Circuit/Network lines -->
            <line x1="50" y1="25" x2="65" y2="25" stroke="white" stroke-width="2" />
            <line x1="50" y1="35" x2="65" y2="35" stroke="white" stroke-width="2" />
            <line x1="50" y1="45" x2="65" y2="45" stroke="white" stroke-width="2" />
            <line x1="50" y1="55" x2="65" y2="55" stroke="white" stroke-width="2" />

            <!-- Connection nodes -->
            <circle cx="50" cy="25" r="2" fill="white" />
            <circle cx="50" cy="35" r="2" fill="white" />
            <circle cx="50" cy="45" r="2" fill="white" />
            <circle cx="50" cy="55" r="2" fill="white" />
            <circle cx="65" cy="25" r="2" fill="white" />
            <circle cx="65" cy="35" r="2" fill="white" />
            <circle cx="65" cy="45" r="2" fill="white" />
            <circle cx="65" cy="55" r="2" fill="white" />
          </g>

          <!-- Company name -->
          <text x="85" y="20" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#2d8c8c">
            MAHSOFT
          </text>
          <text x="85" y="35" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333">
            Engineering
          </text>
          <text x="85" y="50" font-family="Arial, sans-serif" font-size="10" fill="#666">
            (003198940-K)
          </text>
          <text x="85" y="62" font-family="Arial, sans-serif" font-size="9" fill="#888">
            Server Maintenance Services
          </text>
        </svg>
      </div>

      <div class="company-name" id="company-name">
        <h3 class="font-audiowide" style="display: inline; margin-right: 2px;">MAHSOFT Engineering</h3>
        <small>(003198940-K)</small>
      </div>
      <div class="company-info">
        <div id="company-address">No 3436 Mukim 9, Kampung Tok Elong, Tanah Lat, 14000 Bukit Mertajam, Pulau Pinang
        </div>
        <div>Email: <span id="company-email">aqi852000@gmail.com</span> | H/P: <span id="company-phone">018 766
            9492</span></div>
        <div>Server Maintenance & IT Engineering Services</div>
      </div>
    </div>

    <!-- Customer Section -->
    <div class="customer-section">
      <h2>MAKLUMAT PELANGGAN</h2>
      <div class="customer-info">
        <div>
          <div class="customer-name" id="customer-name">MENTERI BESAR KEDAH INCORPORATED</div>
          <div class="customer-details">
            <div id="customer-department">Pejabat Perbadanan Menteri Besar Kedah</div>
            <div id="customer-address">Aras 3, Blok A, Wisma Darul Aman</div>
            <div id="customer-address2">05503 Alor Setar, Kedah Darul Aman.</div>
          </div>
        </div>
        <div>
          <div class="attention">Perhatian: <span id="customer-attention">En. Tarmizi</span></div>
          <div style="margin-top: 10px;">
            <div>Tel: <span id="customer-phone">-</span></div>
            <div>Email: <span id="customer-email">-</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="header">
      <h1>LAPORAN PENYELENGGARAAN SERVER</h1>
      <div style="margin-top: 8px; font-size: 11px;">
        ID Laporan: <span id="report-id">-</span> |
        Tarikh: <span id="report-date">-</span>
      </div>
    </div>

    <!-- Maklumat Asas -->
    <div class="section">
      <h2>MAKLUMAT PENYELENGGARAAN</h2>
      <table class="info-table">
        <tr>
          <td class="label">Tarikh Pemeriksaan</td>
          <td id="inspection-date">-</td>
          <td class="label">Lokasi</td>
          <td id="location">-</td>
        </tr>
        <tr>
          <td class="label">Masa Mula</td>
          <td id="start-time">-</td>
          <td class="label">Masa Selesai</td>
          <td id="end-time">-</td>
        </tr>
        <tr>
          <td class="label">Juruteknik</td>
          <td id="technician">-</td>
          <td class="label">Tempoh (jam)</td>
          <td id="duration">-</td>
        </tr>
      </table>
    </div>

    <!-- Maklumat Server -->
    <div class="section">
      <h2>MAKLUMAT SERVER</h2>
      <table class="info-table">
        <tr>
          <td class="label">Nama Server</td>
          <td id="server-name">-</td>
        </tr>
        <tr>
          <td class="label">Model</td>
          <td id="server-model">-</td>
        </tr>
        <tr>
          <td class="label">Processor</td>
          <td id="processor">-</td>
        </tr>
        <tr>
          <td class="label">Memory (RAM)</td>
          <td id="memory">-</td>
        </tr>
        <tr>
          <td class="label">Storage</td>
          <td id="storage">-</td>
        </tr>
        <tr>
          <td class="label">Sistem Operasi</td>
          <td id="operating-system">-</td>
        </tr>
        <tr>
          <td class="label">Fungsi Utama</td>
          <td id="server-purpose">-</td>
        </tr>
      </table>
    </div>

    <!-- Pemeriksaan Hardware -->
    <div class="section">
      <h2>PEMERIKSAAN HARDWARE</h2>
      <table class="info-table">
        <thead>
          <tr>
            <th>Komponen</th>
            <th>Nilai Diukur</th>
            <th class="status">Status</th>
            <th class="remark">Catatan</th>
          </tr>
        </thead>
        <tbody id="hardware-checks">
          <!-- Data akan diisi oleh JavaScript -->
        </tbody>
      </table>
    </div>

    <!-- Pemeriksaan Software -->
    <div class="section">
      <h2>PEMERIKSAAN SOFTWARE</h2>
      <table class="info-table">
        <thead>
          <tr>
            <th>Komponen</th>
            <th>Versi/Status</th>
            <th class="status">Status</th>
            <th class="remark">Catatan</th>
          </tr>
        </thead>
        <tbody id="software-checks">
          <!-- Data akan diisi oleh JavaScript -->
        </tbody>
      </table>
    </div>

    <!-- Pemeriksaan Performance & Cleanup -->
    <div class="section">
      <h2>PERFORMANCE & CLEANUP</h2>
      <table class="info-table">
        <thead>
          <tr>
            <th>Aktiviti</th>
            <th>Nilai Diukur</th>
            <th class="status">Status</th>
            <th class="remark">Catatan</th>
          </tr>
        </thead>
        <tbody id="performance-cleanup">
          <!-- Data akan diisi oleh JavaScript -->
        </tbody>
      </table>
    </div>

    <!-- Pemeriksaan Backup -->
    <div class="section">
      <h2>STATUS BACKUP</h2>
      <table class="info-table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Nilai/Status</th>
            <th class="cond">Kondisi</th>
            <th class="remark">Catatan</th>
          </tr>
        </thead>
        <tbody id="backup-status">
          <!-- Data akan diisi oleh JavaScript -->
        </tbody>
      </table>
    </div>

    <!-- Analisis Disk Cleanup -->
    <div class="section" id="disk-cleanup-section" style="display: none;">
      <h2>ANALISIS DISK CLEANUP</h2>
      
      <!-- Summary -->
      <div class="notes" style="margin-bottom: 15px;">
        <strong>Ringkasan:</strong> <span id="disk-cleanup-summary">-</span>
      </div>

      <!-- Disk Usage Breakdown -->
      <h3 style="font-size: 14px; color: #2d8c8c; margin-top: 15px; margin-bottom: 10px;">Penggunaan Disk Space</h3>
      <table class="info-table">
        <thead>
          <tr>
            <th>Direktori</th>
            <th>Saiz</th>
            <th style="white-space: nowrap;">Selamat Cleanup?</th>
            <th>Impact WordPress</th>
            <th>Impact Email</th>
            <th>Potensi Savings</th>
          </tr>
        </thead>
        <tbody id="disk-usage-breakdown">
          <!-- Data akan diisi oleh JavaScript -->
        </tbody>
      </table>

      <!-- Cleanup Priority -->
      <h3 style="font-size: 14px; color: #2d8c8c; margin-top: 15px; margin-bottom: 10px;">Priority Cleanup</h3>
      <table class="info-table">
        <thead>
          <tr>
            <th>Priority</th>
            <th>Target</th>
            <th>Expected Savings</th>
            <th>Risk Level</th>
            <th>Impact</th>
          </tr>
        </thead>
        <tbody id="cleanup-priority">
          <!-- Data akan diisi oleh JavaScript -->
        </tbody>
      </table>

      <!-- Safe Cleanup Items -->
      <h3 style="font-size: 14px; color: #2d8c8c; margin-top: 15px; margin-bottom: 10px;">Items Selamat untuk Cleanup</h3>
      <table class="info-table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Lokasi</th>
            <th>Cadangan</th>
          </tr>
        </thead>
        <tbody id="safe-cleanup-items">
          <!-- Data akan diisi oleh JavaScript -->
        </tbody>
      </table>

      <!-- Target Goal -->
      <div class="notes" style="margin-top: 15px;">
        <strong>Target Goal:</strong><br>
        <span id="target-goal">-</span>
      </div>

      <!-- Conclusion -->
      <div class="notes" style="margin-top: 10px; background: #fff3cd; border-color: #ffc107;">
        <strong>Kesimpulan:</strong><br>
        <span id="disk-cleanup-conclusion">-</span>
      </div>
    </div>

    <!-- Pengesahan -->
    <div class="signature-section">
      <div class="signature-box">
        <div><strong>JURUTEKNIK</strong></div>
        <div class="signature-line">
          <span id="technician-name" style="font-style: italic; text-align: center;"></span>
        </div>
        <div style="font-size: 10px;">
          Nama & Tandatangan<br>
          Tarikh: <span id="tech-date">-</span>
        </div>
      </div>
      <div class="signature-box">
        <div><strong>PENGESAHAN CUSTOMER</strong></div>
        <div class="signature-line"></div>
        <div style="font-size: 10px;">
          Nama & Tandatangan<br>
          Tarikh: ______________
        </div>
      </div>
    </div>

    <div class="footer">
      <p><strong>Laporan Penyelenggaraan</strong></p>
      <p>Dokumen ini mengesahkan penyelenggaraan telah dijalankan mengikut prosedur standard</p>
      <p>Tarikh Jana: <span id="generated-date">-</span></p>
    </div>
  </div>

  <script>
    let currentMaintenanceData = null;

    // Fungsi untuk print dengan nama fail custom
    function printReport() {
      if (!currentMaintenanceData) {
        alert('Tiada data untuk dicetak. Sila muat data terlebih dahulu.');
        return;
      }

      // Simpan title asal
      const originalTitle = document.title;
      
      // Dapatkan ID laporan dan tarikh
      const reportId = document.getElementById('report-id').textContent || 'unknown';
      const reportDate = document.getElementById('report-date').textContent || 'unknown';
      
      // Format tarikh untuk nama fail (tukar / kepada -)
      const formattedDate = reportDate.replace(/\//g, '-');
      
      // Set title baru untuk nama fail
      document.title = `report-${formattedDate}-${reportId}`;
      
      // Print
      window.print();
      
      // Kembalikan title asal selepas print
      setTimeout(() => {
        document.title = originalTitle;
      }, 1000);
    }

    // Fungsi untuk memuat data dari fail JSON
    function loadFromFile() {
      const fileInput = document.getElementById('jsonFileInput');
      const file = fileInput.files[0];

      if (!file) return;

      const reader = new FileReader();
      reader.onload = function (e) {
        try {
          const jsonData = JSON.parse(e.target.result);
          currentMaintenanceData = jsonData;
          populateReport();
          showReport();
        } catch (error) {
          showError('Fail JSON tidak sah: ' + error.message);
        }
      };
      reader.readAsText(file);
    }

    // Fungsi untuk memuat data contoh
    function loadSampleData() {
      currentMaintenanceData = getSampleData();
      populateReport();
      showReport();
    }

    // Fungsi untuk menunjukkan laporan
    function showReport() {
      document.getElementById('loading').style.display = 'none';
      document.getElementById('error').style.display = 'none';
      document.getElementById('report-content').style.display = 'block';
    }

    // Fungsi untuk menunjukkan ralat
    function showError(message) {
      document.getElementById('error-message').textContent = message;
      document.getElementById('loading').style.display = 'none';
      document.getElementById('report-content').style.display = 'none';
      document.getElementById('error').style.display = 'block';
    }

    // Fungsi untuk mengisi laporan dengan data
    function populateReport() {
      if (!currentMaintenanceData) return;

      const data = currentMaintenanceData;

      // Company info (can be customized via JSON)
      if (data.company_info) {
        if (data.company_info.name) {
          document.getElementById('company-name').textContent = data.company_info.name;
        }
        if (data.company_info.address) {
          document.getElementById('company-address').textContent = data.company_info.address;
        }
        if (data.company_info.phone) {
          document.getElementById('company-phone').textContent = data.company_info.phone;
        }
        if (data.company_info.email) {
          document.getElementById('company-email').textContent = data.company_info.email;
        }
      }

      // Customer info (can be customized via JSON)
      if (data.customer_info) {
        if (data.customer_info.name) {
          document.getElementById('customer-name').textContent = data.customer_info.name;
        }
        if (data.customer_info.department) {
          document.getElementById('customer-department').textContent = data.customer_info.department;
        }
        if (data.customer_info.address) {
          document.getElementById('customer-address').textContent = data.customer_info.address;
        }
        if (data.customer_info.address2) {
          document.getElementById('customer-address2').textContent = data.customer_info.address2;
        }
        if (data.customer_info.attention) {
          document.getElementById('customer-attention').textContent = data.customer_info.attention;
        }
        if (data.customer_info.phone) {
          document.getElementById('customer-phone').textContent = data.customer_info.phone;
        }
        if (data.customer_info.email) {
          document.getElementById('customer-email').textContent = data.customer_info.email;
        }
      }

      // Basic info
      document.getElementById('report-id').textContent = data.report_info.report_id;
      document.getElementById('report-date').textContent = data.report_info.date;
      document.getElementById('inspection-date').textContent = data.report_info.date;
      document.getElementById('start-time').textContent = data.report_info.start_time;
      document.getElementById('end-time').textContent = data.report_info.end_time;
      document.getElementById('technician').textContent = data.report_info.technician;
      document.getElementById('location').textContent = data.report_info.location;

      // Calculate duration
      const duration = calculateDuration(data.report_info.start_time, data.report_info.end_time);
      document.getElementById('duration').textContent = duration;

      // Server info
      document.getElementById('server-name').textContent = data.server_info.name;
      document.getElementById('server-model').textContent = data.server_info.model;
      document.getElementById('processor').textContent = data.server_info.processor;
      document.getElementById('memory').textContent = data.server_info.memory;
      document.getElementById('storage').textContent = data.server_info.storage;
      document.getElementById('operating-system').textContent = data.server_info.os;
      document.getElementById('server-purpose').textContent = data.server_info.purpose;

      // Hardware checks
      populateTable('hardware-checks', data.hardware_checks);

      // Software checks
      populateTable('software-checks', data.software_checks);

      // Performance & Cleanup
      populateTable('performance-cleanup', data.performance_cleanup);

      // Backup status
      populateTable('backup-status', data.backup_status);

      // Disk Cleanup Analysis
      if (data.disk_cleanup_analysis) {
        populateDiskCleanupAnalysis(data.disk_cleanup_analysis);
        document.getElementById('disk-cleanup-section').style.display = 'block';
      } else {
        document.getElementById('disk-cleanup-section').style.display = 'none';
      }

      // Signatures
      document.getElementById('technician-name').textContent = data.report_info.technician;
      document.getElementById('tech-date').textContent = data.report_info.date;

      // Generated date
      document.getElementById('generated-date').textContent = new Date().toLocaleString('ms-MY');
    }

    function populateTable(tableId, data) {
      const tbody = document.getElementById(tableId);
      tbody.innerHTML = '';

      data.forEach(item => {
        const row = document.createElement('tr');
        const statusClass = item.status === 'OK' ? 'status-ok' :
          item.status === 'WARNING' ? 'status-warning' : 'status-error';
        const conditionClass = item.condition === 'NORMAL' || item.condition === 'ACTIVE' || item.condition === 'SECURE' ? 'status-ok' :
          item.condition === 'WARNING' ? 'status-warning' : 'status-error';

        row.innerHTML = `
                    <td><strong>${item.component || item.item}</strong></td>
                    <td><span class="measurement">${item.measured_value || item.version_status || item.value_status}</span></td>
                    <td><span class="${statusClass || conditionClass}">${item.status || item.condition}</span></td>
                    <td>${item.notes}</td>
                `;
        tbody.appendChild(row);
      });
    }

    function populateDiskCleanupAnalysis(analysis) {
      // Summary
      if (analysis.summary) {
        document.getElementById('disk-cleanup-summary').textContent = analysis.summary;
      }

      // Disk Usage Breakdown
      if (analysis.disk_usage_breakdown) {
        const breakdownTbody = document.getElementById('disk-usage-breakdown');
        breakdownTbody.innerHTML = '';
        analysis.disk_usage_breakdown.forEach(item => {
          const row = document.createElement('tr');
          const safeClass = item.safe_to_cleanup ? 'status-ok' : 'status-warning';
          row.innerHTML = `
            <td><strong>${item.directory}</strong></td>
            <td>${item.size} (${item.percentage})</td>
            <td><span class="${safeClass}">${item.safe_to_cleanup ? 'YA' : 'TIDAK'}</span></td>
            <td>${item.impact_on_wordpress}</td>
            <td>${item.impact_on_email}</td>
            <td><strong>${item.cleanup_potential}</strong></td>
          `;
          breakdownTbody.appendChild(row);
        });
      }

      // Cleanup Priority
      if (analysis.cleanup_priority) {
        const priorityTbody = document.getElementById('cleanup-priority');
        priorityTbody.innerHTML = '';
        analysis.cleanup_priority.forEach(item => {
          const row = document.createElement('tr');
          const riskClass = item.risk_level === 'LOW' ? 'status-ok' : 
                          item.risk_level === 'MEDIUM' ? 'status-warning' : 'status-error';
          row.innerHTML = `
            <td><strong>Priority ${item.priority}</strong></td>
            <td>${item.target}</td>
            <td><strong>${item.expected_savings}</strong></td>
            <td><span class="${riskClass}">${item.risk_level}</span></td>
            <td>${item.impact}</td>
          `;
          priorityTbody.appendChild(row);
        });
      }

      // Safe Cleanup Items
      if (analysis.safe_cleanup_items) {
        const safeTbody = document.getElementById('safe-cleanup-items');
        safeTbody.innerHTML = '';
        analysis.safe_cleanup_items.forEach(item => {
          const row = document.createElement('tr');
          row.innerHTML = `
            <td><strong>${item.item}</strong></td>
            <td><code>${item.location}</code></td>
            <td>${item.recommendation}</td>
          `;
          safeTbody.appendChild(row);
        });
      }

      // Target Goal
      if (analysis.target_goal) {
        const goal = analysis.target_goal;
        document.getElementById('target-goal').innerHTML = `
          Current Free Space: <strong>${goal.current_free_space}</strong><br>
          Target Free Space: <strong>${goal.target_free_space}</strong><br>
          Required Cleanup: <strong>${goal.required_cleanup}</strong><br>
          Recommended Approach: ${goal.recommended_approach}
        `;
      }

      // Conclusion
      if (analysis.conclusion) {
        document.getElementById('disk-cleanup-conclusion').textContent = analysis.conclusion;
      }
    }

    function calculateDuration(startTime, endTime) {
      try {
        const start = new Date(`2025-01-01 ${startTime}`);
        const end = new Date(`2025-01-01 ${endTime}`);
        const diffMs = end - start;
        const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
        const diffMins = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
        return `${diffHours} jam ${diffMins} minit`;
      } catch (error) {
        return 'Tidak dapat mengira';
      }
    }

    function exportData() {
      if (!currentMaintenanceData) {
        alert('Tiada data untuk disimpan. Sila muat data terlebih dahulu.');
        return;
      }

      const dataStr = JSON.stringify(currentMaintenanceData, null, 2);
      const dataBlob = new Blob([dataStr], { type: 'application/json' });
      const url = URL.createObjectURL(dataBlob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `laporan_maintenance_${currentMaintenanceData.report_info.report_id}.json`;
      link.click();
      URL.revokeObjectURL(url);
    }

    // Tambah event listener untuk Ctrl+P
    document.addEventListener('keydown', function(event) {
      if (event.ctrlKey && event.key === 'p') {
        event.preventDefault();
        printReport();
      }
    });

    // Load sample data on page load for demonstration
    window.addEventListener('load', function () {
      // You can uncomment this line to load sample data automatically
      // loadSampleData();
    });
  </script>
</body>

</html>